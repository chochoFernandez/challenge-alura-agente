# Copiá este archivo a .env y completá los valores reales.
# El .env NUNCA se sube al repositorio (está en .gitignore).

# --- Obligatorio ---
# API key de Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Modelos (opcionales, tienen default) ---
# Ojo: gemini-2.5-flash y anteriores ya no se habilitan para keys nuevas (la API responde
# 404 "no longer available to new users"). Alternativa probada: gemini-3-flash-preview.
GEMINI_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# --- Retrieval (opcionales, tienen default) ---
# Cantidad de fragmentos a recuperar por pregunta.
TOP_K=4
# Umbral de similitud coseno [0-1]. Por debajo de esto el agente responde "no lo sé"
# en vez de arriesgar una respuesta. Se calibra con scripts/eval_questions.py.
SIMILARITY_THRESHOLD=0.66

# --- Rutas (opcionales, tienen default) ---
DOCS_DIR=data/docs
INDEX_DIR=data/index
LOG_PATH=logs/executions.jsonl
